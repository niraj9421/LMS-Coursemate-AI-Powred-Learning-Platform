# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_min_32_chars_xxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_min_32_chars_xxxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your@gmail.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ─── AI Services ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=

# ─── News API ─────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_news_api_key

# ─── App URLs ─────────────────────────────────────────────────────────────────
# In production set FRONTEND_URL to your deployed frontend (Netlify/Vercel URL)
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:5001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated. Add your production frontend URL here:
# ALLOWED_ORIGINS=http://localhost:5173,https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
